---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import keywordsData from '../../keywords.json';

const allArticles = (keywordsData.completed || []).map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));

export const frontmatter = {
  title: "Aparat vidat alimente profesional",
  excerpt: "Un aparat vidat alimente profesional este unealta esentiala pentru orice bucatarie care isi doreste conservarea optima a alimentelor, reducerea risipei si optim",
  image: "/images/articles/aparat-vidat-alimente-profesional.webp",
  category: "Electrocasnice Premium",
  categorySlug: "electrocasnice-premium",
  date: "2026-03-13T11:47:18.368Z",
  author: "Mihai Florescu",
  authorRole: "Expert Electrocasnice",
  authorBio: "Cu peste 12 ani in industria electrocasnicelor, Mihai testeaza personal fiecare aparat si ofera recenzii bazate pe utilizare reala, nu doar specificatii din catalog."
};

const faq = [{"question":"Cat costa un aparat vidat alimente profesional?","answer":"Pretul unui aparat vidat alimente profesional variaza intre 499 lei pentru modelele entry-level cu functii de baza si poate ajunge pana la 2000 lei sau chiar mai mult pentru aparatele de tip chamber sau cele cu functii avansate si materiale premium."},{"question":"Care este diferenta intre un aparat vidat casnic si unul profesional?","answer":"Un aparat profesional are o pompa de vid mai puternica (presiune de -0.8 bari si peste), materiale de constructie mai durabile (otel inoxidabil), o bara de etansare mai lata si functii suplimentare precum moduri presetate, puls manual sau functie de marinate. Este conceput pentru uz intensiv."},{"question":"Merita sa cumpar un aparat vidat pentru lichide?","answer":"Da, daca prepari frecvent supe, ciorbe, sosuri sau marinade, un aparat vidat special conceput pentru lichide (tip chamber) este esential. Acestea previn aspirarea lichidului in pompa si asigura o etansare sigura, prelungind durata de conservare a preparatelor lichide."},{"question":"Cat de mult prelungeste durata de viata a alimentelor un aparat vidat?","answer":"Vidarea alimentelor poate prelungi durata lor de conservare de pana la 5 ori comparativ cu depozitarea in frigider fara vid. De exemplu, carnea proaspata poate rezista in frigider 1-2 zile fara vid, dar pana la 5-7 zile cu vid. Legumele pot rezista saptamani in loc de zile."},{"question":"Ce tipuri de pungi pot folosi pentru un aparat vidat profesional?","answer":"Aparatele profesionale folosesc de obicei pungi gofrate (texturate) pentru modelele externe, pentru a permite extragerea aerului. Aparatele de tip chamber pot folosi pungi netede. Este recomandat sa folositi pungi specifice aparatului dvs. pentru a asigura o etansare optima si sigura."}];
