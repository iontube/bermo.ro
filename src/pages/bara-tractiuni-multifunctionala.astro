---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import PrevNextNav from '../components/PrevNextNav.astro';
import keywordsData from '../../keywords.json';

const allArticles = (keywordsData.completed || []).map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));

export const frontmatter = {
  title: "Bara tractiuni multifunctionala",
  excerpt: "Daca ai cautat o bara tractiuni multifunctionala, cel mai probabil iti doresti sa iti transformi propria casa intr-un mic centru de fitness, capabil sa ofere o ",
  image: "/images/articles/bara-tractiuni-multifunctionala.webp",
  category: "Fitness si Sport",
  categorySlug: "fitness-sport",
  date: "2026-03-12T11:41:38.000Z",
  author: "Dan Iordan",
  authorRole: "Antrenor Fitness Certificat",
  authorBio: "Antrenor personal cu certificari internationale, Dan testeaza echipamente fitness si recomanda doar cele care ofera rezultate reale pentru antrenamente de acasa."
};

const faq = [{"question":"Cat costa o bara tractiuni multifunctionala?","answer":"Preturile pentru o bara tractiuni multifunctionala variaza semnificativ. Modelele simple, de usa, pot fi gasite de la 99 RON. Power towers-urile incep de la aproximativ 1000 RON si pot ajunge pana la 1600 RON pentru modele cu functii extinse. Barele de perete/tavan de calitate se situeaza in jur de 500 RON."},{"question":"Ce greutate maxima suporta o bara tractiuni multifunctionala?","answer":"Greutatea maxima admisa variaza in functie de tipul si calitatea constructiei. Barele de usa suporta de obicei pana la 100-120 kg. Power towers-urile pot sustine 130-150 kg, iar barele de perete/tavan de calitate, construite din otel masiv, pot ajunge pana la 180 kg sau chiar mai mult."},{"question":"Merita sa cumpar un power tower in loc de o sala de sport?","answer":"Da, merita daca doresti sa economisesti timp si bani pe termen lung si ai spatiul necesar. Un power tower ofera versatilitate pentru antrenamentul intregului corp, permițându-ți să te antrenezi oricand. Totuși, nu înlocuiește complet complexitatea și varietatea oferite de o sală de sport complet echipată."},{"question":"Ce diferenta este intre o bara de tractiuni simpla si una multifunctionala?","answer":"O bara de tractiuni simpla permite exclusiv efectuarea tracțiunilor, cu diferite prize. O bara tractiuni multifunctionala, cum este un power tower, adaugă funcționalități precum stații pentru dips, flotări, abdomene sau ridicări de genunchi, permițând un antrenament mult mai complet al corpului."},{"question":"Cum aleg bara tractiuni potrivita pentru apartamentul meu?","answer":"Pentru apartamente, ia in considerare spatiul disponibil. Barele de usa sunt ideale pentru spații mici si inchiriate. Barele de perete/tavan economisesc spatiu la sol, dar necesita montaj. Power towers sunt mai voluminoase, dar ofera cea mai mare versatilitate; alege un model compact daca spatiul este o provocare."}];
