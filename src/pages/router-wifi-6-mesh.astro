import keywordsData from '../../keywords.json';

const allArticles = (keywordsData.completed || []).map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));

export const frontmatter = {
  title: "Router wifi 6 mesh",
  excerpt: "Daca cauti performanta si acoperire Wi-Fi fara intreruperi in toata casa, un sistem router wifi 6 mesh este solutia ideala. Aceste sisteme combina un router pri",
  image: "/images/articles/router-wifi-6-mesh.webp",
  category: "IT si Electronice",
  categorySlug: "it-electronice",
  date: "2026-03-14T11:37:18.911Z",
  author: "Radu Petre",
  authorRole: "Specialist IT & Gaming",
  authorBio: "Inginer IT si gamer pasionat, Radu analizeaza laptopuri si componente din perspectiva performantei reale in jocuri si aplicatii profesionale."
};

const faq = [{"question":"Cat costa un sistem router wifi 6 mesh bun?","answer":"Preturile pentru un sistem router wifi 6 mesh bun variaza considerabil. Cele mai accesibile, precum TP-Link Deco X20 (3-pack), incep de la aproximativ 700-900 lei. Modelele de performanta medie spre inalta, cum ar fi ASUS ZenWiFi XT8 (2-pack) sau Netgear Nighthawk AX8, pot ajunge la 1500-2500 lei sau chiar mai mult pentru pachete cu mai multe unitati sau specificatii superioare."},{"question":"Care e diferenta intre un router mesh si un range extender?","answer":"Un range extender mareste semnalul unui router existent, dar adesea imparte viteza pe jumatate si creeaza o retea separata. Un sistem mesh, in schimb, creeaza o singura retea unificata cu routerul principal si unitatile satelit, oferind acoperire uniforma, viteze mai mari si comutare automata intre noduri, fara intreruperi."},{"question":"Merita sa upgradez la Wi-Fi 6 mesh daca am deja Wi-Fi 5?","answer":"Merita daca ai multe dispozitive noi compatibile Wi-Fi 6, ai nevoie de viteze mai mari, latenta mai mica pentru jocuri sau streaming 4K/8K, sau daca ai un numar foarte mare de dispozitive conectate simultan. Pentru nevoi moderate, un sistem Wi-Fi 5 mesh performant poate fi inca o optiune buna."},{"question":"Cate unitati mesh am nevoie pentru casa mea?","answer":"Numarul de unitati depinde de suprafata locuintei si de structura acesteia (pereti grosi, etaje multiple). In general, un pachet de 2 unitati este suficient pentru apartamente sau case mici spre medii (pana la 200-250 mp). Pentru case mari (peste 250 mp) sau cu mai multe etaje, un pachet de 3 unitati este recomandat pentru a asigura acoperire completa."},{"question":"Pot folosi un sistem mesh cu routerul meu actual de la ISP?","answer":"Da, majoritatea sistemelor mesh pot fi configurate in modul 'Access Point' (AP Mode). In acest caz, routerul tau actual de la furnizorul de internet ramane activ si gestioneaza conexiunea, iar sistemul mesh se ocupa de distributia semnalului Wi-Fi in toata casa. Asigura-te ca sistemul mesh ales suporta acest mod de operare."}];
