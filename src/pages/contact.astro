---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
---

<Layout
  title="Contact"
  description="Contacteaza echipa Bermo.ro - Suntem aici sa raspundem intrebarilor tale despre produse si recenzii."
>
  <Header />

  <main class="contact-page">
    <div class="container">
      <div class="contact-container">
        <div class="contact-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>

        <h1>Contacteaza-ne</h1>
        <p>
          Ai intrebari despre produsele recenzate sau vrei sa ne transmiti un feedback? Suntem aici sa te ajutam. Trimite-ne un email si iti vom raspunde cat mai curand posibil.
        </p>

        <a href="mailto:contact@bermo.ro" class="contact-email">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="24" height="24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          contact@bermo.ro
        </a>
      </div>
    </div>
  </main>

  <Footer />
  <CookieBanner />
</Layout>
